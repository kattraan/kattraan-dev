# Copy to .env and fill in values. Never commit .env.

PORT=5000
CLIENT_URL=http://localhost:5173
MONGO_URI=

JWT_SECRET=
JWT_REFRESH_SECRET=

# Razorpay (Dashboard → API Keys — use Live keys in production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Webhooks → POST /api/webhooks/razorpay — signing secret
# Subscribe to: payment.captured, payment.failed (see server/docs/RAZORPAY_RUNBOOK.md)
RAZORPAY_WEBHOOK_SECRET=
