# Copy to .env and fill in values. Never commit .env.

PORT=5000
CLIENT_URL=http://localhost:5173
# Production frontend URL (uncomment when you move to production)
# CLIENT_URL=https://www.kattraan.com
MONGO_URI=

# Must be named JWT_* (not JMT_*). Required for login/refresh cookies.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Optional: strict | lax | none. If unset, production uses none when CLIENT_URL host
# differs from RENDER_EXTERNAL_URL / API_PUBLIC_URL (Vercel + Render).
# AUTH_COOKIE_SAME_SITE=

# Cashfree (Dashboard → API Keys — use production keys in production)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
# Optional overrides for return / webhook URLs
# CASHFREE_RETURN_URL=
# CASHFREE_NOTIFY_URL=

# Bunny Stream
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
# Prefer the library Read-Only API key for webhook HMAC (falls back to BUNNY_API_KEY)
# BUNNY_STREAM_WEBHOOK_SECRET=

# Initial admin (created once on first boot if missing; never resets existing password)
# ADMIN_EMAIL=admin@kattran.com
# ADMIN_PASSWORD=
