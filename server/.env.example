# Copy to .env and fill in values. Never commit .env.

PORT=5000
CLIENT_URL=http://localhost:5173
MONGO_URI=

# Must be named JWT_* (not JMT_*). Required for login/refresh cookies.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Optional: strict | lax | none. If unset, production uses none when CLIENT_URL host
# differs from RENDER_EXTERNAL_URL / API_PUBLIC_URL (Vercel + Render).
# AUTH_COOKIE_SAME_SITE=

# Razorpay (Dashboard → API Keys — use Live keys in production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Webhooks → POST /api/webhooks/razorpay — signing secret
# Subscribe to: payment.captured, payment.failed (see server/docs/RAZORPAY_RUNBOOK.md)
RAZORPAY_WEBHOOK_SECRET=
