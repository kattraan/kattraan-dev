# API base URL (required in production). Use your Render URL with or without trailing /api — the client normalizes to .../api.
# Examples: https://your-app.onrender.com  OR  https://your-app.onrender.com/api
VITE_API_URL=http://localhost:5000/api
# Production backend URL (uncomment when you move to production)
# VITE_API_URL=https://kattraan-dev.onrender.com
